# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_NAME=hotel_management
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client URL (required for production CORS)
CLIENT_URL=http://localhost:5173

# Redis (required for job queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OTA Integration
OTA_ENCRYPTION_KEY=your-32-byte-hex-key-for-encrypting-ota-credentials
OTA_WEBHOOK_BASE_URL=https://your-domain.com/api/v1/webhooks

# Email / SMTP (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Hotel PMS" <noreply@hotel.com>

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_BUSINESS_ID=your-whatsapp-business-account-id
HOTEL_WHATSAPP_NUMBER=91XXXXXXXXXX
